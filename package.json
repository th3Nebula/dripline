{
  "name": "dripline",
  "version": "0.2.0",
  "description": "Query APIs using SQL",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./plugins/github": "./dist/plugins/github.js",
    "./plugins/utils/http": "./dist/plugins/utils/http.js"
  },
  "bin": {
    "dripline": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "npx tsx src/main.ts",
    "test": "npx tsx --test src/tests/**/*.test.ts",
    "smoke": "npx tsx smoke.ts",
    "format": "npx @biomejs/biome format --write src/",
    "lint": "npx @biomejs/biome lint src/",
    "check": "npx @biomejs/biome check src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Michaelliv/dripline.git"
  },
  "homepage": "https://github.com/Michaelliv/dripline#readme",
  "bugs": {
    "url": "https://github.com/Michaelliv/dripline/issues"
  },
  "keywords": [
    "sql",
    "cloud",
    "api",
    "query",
    "steampipe",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "duckdb": "^1.4.4",
    "duckdb-async": "^1.4.2",
    "nanoid": "^5.1.6"
  }
}
